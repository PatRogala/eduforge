/ Main header
%header{class: "bg-blue-500 text-white py-2 shadow-[0_3px_0_0_theme(colors.blue.700)]"}
  .flex.justify-between.items-center.px-4
    / --- Left Section: Menu Toggle & Logo/App Name ---
    .flex.items-center
      / Sidebar Toggle Button
      %button.p-2.mr-3.rounded-sm.focus:outline-none.transition-all.duration-100.ease-in-out{class: "bg-blue-600 hover:bg-blue-700 border-2 border-blue-800 shadow-[2px_2px_0_0_theme(colors.blue.900)] active:translate-y-[1px] active:shadow-[1px_1px_0_0_theme(colors.blue.900)]", "data-action": "click->sidebar#toggle"}
        = lucide_icon("menu", class: "text-white w-5 h-5")

      / Logo & App Name
      .flex.items-center
        / Logo "Block"
        .h-8.w-8.flex.items-center.justify-center.mr-2.rounded-sm{class: "bg-orange-500 border-2 border-orange-700 shadow-[2px_2px_0_0_theme(colors.orange.800)]"}
          %span.text-white.font-bold.text-lg.select-none= t("app.name")[0]
        / App Name
        %span.font-bold.text-xl.text-white.select-none{class: "drop-shadow-[1.5px_1.5px_0_rgba(0,0,0,0.25)]"}= t("app.name")

    / --- Search Bar (Desktop) ---
    .hidden.md:flex.items-center.px-3.rounded-sm.flex-1.max-w-xl.mx-4.py-1{class: "bg-blue-100 border-2 border-blue-300 shadow-inner-lg"}
      = lucide_icon("search", class: "text-blue-600 h-5 mr-2")
      %input.bg-transparent.border-none.outline-none.w-full.text-sm.text-blue-800.placeholder-blue-500{placeholder: t(".search.placeholder"), type: "text"}

    / --- Right Section: Mobile Search & Auth Links/User Avatar ---
    .flex.items-center.space-x-3
      / Mobile Search Button
      %button.md:hidden.p-2.rounded-sm.focus:outline-none.transition-all.duration-100.ease-in-out{class: "bg-blue-600 hover:bg-blue-700 border-2 border-blue-800 shadow-[2px_2px_0_0_theme(colors.blue.900)] active:translate-y-[1px] active:shadow-[1px_1px_0_0_theme(colors.blue.900)]"}
        = lucide_icon("search", class: "text-white h-5 w-5")

      / Authentication Section
      - if logged_in?
        .relative{"data-controller": "dropdown"}
          %button.flex.items-center.cursor-pointer{"data-action": "dropdown#toggle click@window->dropdown#hide"}
            - if user_avatar.attached?
              = image_tag user_avatar, class: "w-9 h-9 rounded-sm object-cover border-2 border-white shadow-[2px_2px_0_0_rgba(0,0,0,0.3)]"
            - else
              / Voxel-style Placeholder Avatar
              .w-9.h-9.rounded-sm.flex.items-center.justify-center{class: "bg-orange-300 border-2 border-orange-500 shadow-[2px_2px_0_0_theme(colors.orange.600)]"}
                = lucide_icon("user", class: "text-orange-700 h-5 w-5")
          %div{"data-dropdown-target": "menu"}
            = render Layout::HeaderDropdownComponent.new(current_user: current_user)
      - else
        / Sign In Button
        = link_to t(".sign_in"), new_user_session_path, class: "px-4 py-1.5 text-sm font-semibold rounded-sm transition-all duration-100 ease-in-out text-yellow-800 bg-yellow-400 hover:bg-yellow-300 border-2 border-yellow-600 shadow-[2px_2px_0_0_theme(colors.yellow.700)] active:translate-y-[1px] active:shadow-[1px_1px_0_0_theme(colors.yellow.700)]"
        / Sign Up Button
        = link_to t(".sign_up"), new_user_registration_path, class: "px-4 py-1.5 text-sm font-semibold rounded-sm transition-all duration-100 ease-in-out text-white bg-green-500 hover:bg-green-400 border-2 border-green-700 shadow-[2px_2px_0_0_theme(colors.green.800)] active:translate-y-[1px] active:shadow-[1px_1px_0_0_theme(colors.green.800)]"
