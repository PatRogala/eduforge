/ Dropdown Container
.absolute.right-0.mt-2.w-64.animate-fadeIn.z-50{class: "bg-blue-100 rounded-sm border-2 border-blue-300 shadow-[3px_3px_0_0_theme(colors.blue.400)]"}

  / User Info Section
  .px-3.pt-3.pb-2.border-b-2.border-blue-200
    / TODO: Replace "John Doe" with actual user name if available
    %p.text-sm.font-semibold.text-blue-900= "John Doe"
    %p.text-xs.text-blue-700.mt-1= current_user.email

  / Links Section
  .py-2
    = link_to edit_user_registration_path, class: "w-full flex items-center px-3 py-1.5 text-sm text-blue-800 hover:bg-blue-200 hover:text-blue-900 rounded-sm transition-colors duration-100" do
      %span.text-blue-600.mr-2
        = lucide_icon("settings-2", class: "h-4 w-4")
      = t(".account_settings")

  / Logout Section
  .border-t-2.border-blue-200.mt-1.pt-2.pb-2.px-2
    = button_to destroy_user_session_path, method: :delete, class: "w-full px-3 py-1.5 text-sm font-semibold rounded-sm transition-all duration-100 ease-in-out flex items-center justify-center text-white bg-red-500 hover:bg-red-400 border-2 border-red-700 shadow-[2px_2px_0_0_theme(colors.red.800)] active:translate-y-[1px] active:shadow-[1px_1px_0_0_theme(colors.red.800)] cursor-pointer" do
      = lucide_icon("log-out", class: "text-white h-4 w-4 mr-2")
      = t(".log_out")
