/ Sidebar Container
%aside{class: "bg-white border-r-4 border-sky-300 transition-all duration-300 overflow-hidden min-h-screen mt-[3px]", "data-sidebar-target": "aside"}
  .h-full.flex.flex-col.py-4
    %nav.flex-1.px-2
      %ul.space-y-1
        %li
          - public_links.each do |link|
            = render_link(link)
        - if logged_in?
          %li.pt-2.mt-2.border-t.border-sky-200
            - logged_in_links.each do |link|
              = render_link(link)
        - if instructor?
          %li.pt-2.mt-2.border-t.border-sky-200
            - instructor_links.each do |link|
              = render_link(link)
